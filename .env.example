# =============================================================
# TARA DELIVERY — Environment Variables
# Copier ce fichier en .env et remplir toutes les valeurs
# =============================================================

# ── Serveur API ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── Base de données (PostgreSQL) ─────────────────────────────
# En local: localhost:5432   |   En Docker: postgres:5432
DATABASE_URL="  "

# ── Docker Compose ────────────────────────────────────────────
POSTGRES_PASSWORD=tara_dev_password   # Utilisé par docker-compose pour créer le container

# ── JWT (générer avec: openssl rand -hex 32) ──────────────────
JWT_SECRET=CHANGER_CETTE_VALEUR_openssl_rand_hex_32
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGER_CETTE_AUTRE_VALEUR_openssl_rand_hex_32
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Google OAuth ──────────────────────────────────────────────
# Obtenir sur: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=XXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXX
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── Firebase Admin SDK (backend) ─────────────────────────────
# Obtenir sur: console.firebase.google.com → Paramètres → Comptes de service
FIREBASE_PROJECT_ID=tara-delivery-XXXXX
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nVOTRE_CLE_PRIVEE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXXX@tara-delivery-XXXXX.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://tara-delivery-XXXXX-default-rtdb.europe-west1.firebasedatabase.app

# ── MTN MoMo Collections ─────────────────────────────────────
# S'abonner à "Collections" sur: momodeveloper.mtn.com
# Créer API User avec les commandes curl dans INSTALL.md section 4.3
MOMO_SUBSCRIPTION_KEY=votre_collections_primary_key
MOMO_API_USER=uuid_de_votre_api_user
MOMO_API_KEY=api_key_de_votre_api_user
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_ENVIRONMENT=sandbox
# Laisser vide en sandbox si pas de webhook public, on utilise le polling
MOMO_CALLBACK_HOST=

# ── Orange Money CM WebPay ────────────────────────────────────
# S'abonner à "Orange Money Cameroon WebPay" sur: developer.orange.com
# Merchant Key fournie par Orange Money Business Cameroun
ORANGE_CLIENT_ID=votre_client_id
ORANGE_CLIENT_SECRET=votre_client_secret
ORANGE_BASE_URL=https://api.orange.com
ORANGE_MERCHANT_KEY=votre_merchant_key
ORANGE_RETURN_URL=http://localhost:3000/payment/success
ORANGE_CANCEL_URL=http://localhost:3000/payment/cancel
ORANGE_NOTIF_URL=http://localhost:4000/api/webhooks/orange
ORANGE_NOTIF_TOKEN=

# ── SMTP / Email (Nodemailer) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_app_password_gmail
EMAIL_FROM="TARA DELIVERY <noreply@tara-delivery.cm>"

# ── Frontend Next.js (variables publiques) ───────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tara-delivery-XXXXX.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tara-delivery-XXXXX
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://tara-delivery-XXXXX-default-rtdb.europe-west1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=votre_google_maps_key
