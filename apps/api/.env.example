# Database (Supabase PostgreSQL or your own)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Server Configuration
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://tara-delivery.vercel.app

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET="your-refresh-token-secret-change-this"
REFRESH_TOKEN_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="https://api.englishlanguagecertificate.com/api/auth/google/callback"

# Supabase (replaces Firebase)
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# Web Push Notifications (replaces FCM)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# Payment APIs (Cameroon)
# MTN MoMo
MOMO_SUBSCRIPTION_KEY="your-momo-subscription-key"
MOMO_API_USER="your-momo-api-user"
MOMO_API_KEY="your-momo-api-key"
MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
MOMO_ENVIRONMENT="sandbox"

# Orange Money
ORANGE_CLIENT_ID="your-orange-client-id"
ORANGE_CLIENT_SECRET="your-orange-client-secret"
ORANGE_MERCHANT_KEY="your-orange-merchant-key"

# Email SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@taradelivery.com"

# Redis (optional, for caching)
REDIS_URL="redis://localhost:6379"
